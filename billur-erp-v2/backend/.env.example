# BILLUR ERP — backend environment

# Database
DATABASE_URL=postgres://postgres:billur@localhost:5432/billur_erp

# Server
NODE_ENV=development
PORT=3001

# Auth secrets — production'da random 64-byte qiymatlar kerak
JWT_SECRET=change-me-in-production-use-random-64-bytes
QR_SECRET=change-me-in-production-use-random-64-bytes

# CORS — frontend URL'lari
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# BoxApp integration (ixtiyoriy)
# Agar ikkalasi ham sozlangan bo'lsa, har 60 sekundda background sync ishlaydi
# BOXAPP_API_URL=https://app.andbillur.com
# BOXAPP_API_KEY=your-secure-key-here
